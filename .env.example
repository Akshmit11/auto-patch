# Required for live LLM + GitHub runs
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# Optional OpenAI swap path
OPENAI_API_KEY=

# LLM selection (claude | openai)
LLM_PROVIDER=claude
# Product default is Claude Sonnet; override if needed
LLM_MODEL=claude-sonnet-4-6

# Guardrails / limits
MAX_FILES_PER_PATCH=5
MAX_RETRIES=3
SANDBOX_TIMEOUT_SECONDS=300
RUN_TIMEOUT_SECONDS=1800

# Paths (relative to CWD unless absolute)
WORK_DIR=.autopatch/work
LOG_DIR=.autopatch/logs

# Docker sandbox
SANDBOX_IMAGE=python:3.11-slim
DOCKER_NETWORK_DISABLED=true
